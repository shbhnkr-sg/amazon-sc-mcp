# Amazon SP-API OAuth (Login with Amazon)
SP_API_CLIENT_ID=your_client_id
SP_API_CLIENT_SECRET=your_client_secret
SP_API_TOKEN_URL=https://api.amazon.com/auth/o2/token

# Which API models to load (comma-separated, or "all" for everything)
# Leave empty for core models: orders, catalog, listings, inventory, pricing, reports, feeds, finances, notifications, sellers, fees, sales
# SP_API_MODELS=all
# SP_API_MODELS=orders-api-model,catalog-items-api-model,listings-items-api-model
