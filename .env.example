# Amazon SP-API OAuth (Login with Amazon)
SP_API_CLIENT_ID=your_client_id
SP_API_CLIENT_SECRET=your_client_secret
SP_API_REFRESH_TOKEN=your_refresh_token
SP_API_TOKEN_URL=https://api.amazon.com/auth/o2/token

# Which API models to load (comma-separated, or "all" for everything)
# Leave empty for core: orders, catalog, listings, inventory, pricing, reports, feeds, finances, notifications, sellers, fees, sales
# SP_API_MODELS=all
# SP_API_MODELS=orders-api-model,catalog-items-api-model

# Allowed Origin headers for MCP requests (comma-separated, empty = allow all)
# MCP_ALLOWED_ORIGINS=http://localhost:3100,https://yourdomain.com
